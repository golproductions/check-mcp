{
  "name": "@golproductions/check-mcp",
  "version": "1.3.4",
  "description": "Instead of tweaking your prompts to make an AI agent better, just use Check. Validates every command before execution. Instantly saves compute cost on failed retries.",
  "bin": {
    "check-mcp": "src/index.js"
  },
  "type": "module",
  "scripts": {
    "test": "node --test",
    "smoke": "node --check src/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "src/",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "preflight",
    "command-validation",
    "deterministic",
    "ai-agents"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/golproductions/check-mcp.git"
  },
  "homepage": "https://www.golproductions.com/check.html",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  }
}
